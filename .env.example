# SNOO credentials (Happiest Baby account)
SNOO_USERNAME=you@example.com
SNOO_PASSWORD=your-snoo-password

# Huckleberry credentials
HUCKLEBERRY_EMAIL=you@example.com
HUCKLEBERRY_PASSWORD=your-huckleberry-password
HUCKLEBERRY_TIMEZONE=America/New_York

# Optional: hard-code child UID; if unset, auto-detected from get_user().childList[0].cid
# HUCKLEBERRY_CHILD_UID=

# Sync tunables
LOOKBACK_HOURS=6
INTERVAL_MINUTES=15

# Session-building tunables
MERGE_GAP_MINUTES=5
MIN_ASLEEP_MINUTES=5
ASLEEP_RATIO=0.5

# Safety: set to false only after reviewing a dry run
DRY_RUN=true

# SQLite dedupe store path (mount a volume here in Docker)
DB_PATH=/data/dedupe.sqlite
