# SNOO credentials (Happiest Baby account)
SNOO_USERNAME=you@example.com
SNOO_PASSWORD=your-snoo-password

# Huckleberry credentials
HUCKLEBERRY_EMAIL=you@example.com
HUCKLEBERRY_PASSWORD=your-huckleberry-password
HUCKLEBERRY_TIMEZONE=America/New_York

# Optional: hard-code child UIDs; auto-detected from first child if unset
# SNOO_BABY_ID=
# HUCKLEBERRY_CHILD_UID=

# Optional: sleep location category tag to assign in Huckleberry
# Choices: car, nursing, wornOrHeld, stroller, coSleep, nextToCarer, onOwnInBed, bottle, swing
# HUCKLEBERRY_SLEEP_LOCATION=onOwnInBed

# How often to poll the SNOO device (minutes)
INTERVAL_MINUTES=15

# Optional: discard sleep sessions shorter than this threshold (default is 1 minute)
MIN_SESSION_MINUTES=5

# Optional: number of days of SNOO history to sync (default is 2)
# Increase this (e.g. to 7 or 14) during first-time setup to backfill older data
HISTORY_DAYS=2

# Set to true to log intended writes without touching Huckleberry
DRY_RUN=false

# SQLite dedupe store path (mount a volume here in Docker; leave unset to use /data/dedupe.sqlite)
# DB_PATH=./dedupe.sqlite
